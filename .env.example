# Capillary — environment template.
# Copy to `.env` (next to docker-compose.yml) and fill in as needed:
#   cp .env.example .env
# Docker Compose automatically loads `.env`. None of these are committed.

# ---------------------------------------------------------------------------
# Container image (registry-first)
# ---------------------------------------------------------------------------
# The published image to run. Point this at your GHCR repo once it exists.
# Leave as-is to build locally with `make docker-up`.
CAPILLARY_IMAGE=ghcr.io/OWNER/REPO:latest
# Host port to expose the app on (container always listens on 8080).
CAPILLARY_PORT=8080

# ---------------------------------------------------------------------------
# Core server
# ---------------------------------------------------------------------------
# Comma-separated allow-list of browser origins for CORS + CSRF. Must include
# the URL users load the app from. For a single-host deploy this is that host.
CORS_ORIGIN=http://localhost:8080
# Require a connected GitHub identity before any /api/* call is served.
CAPILLARY_REQUIRE_GITHUB_LOGIN=1

# ---------------------------------------------------------------------------
# GitHub OAuth (login + repository/PR access)
# ---------------------------------------------------------------------------
# Device-flow only needs the client id. The web callback flow also needs the
# secret and a redirect URI registered on your OAuth app.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_REDIRECT_URI=
GITHUB_OAUTH_SCOPES=repo workflow read:org read:user

# ---------------------------------------------------------------------------
# LLM planner credentials (SERVER-SIDE ONLY)
# ---------------------------------------------------------------------------
# Keys are read exclusively from this environment and are never accepted over
# the API. Set only the provider you use. Preferred providers (Codex CLI,
# Claude Code, GitHub Copilot) authenticate via CLI/OAuth and need no key here.
#   - Codex CLI (stdio):      uses `codex` CLI login (no key)
#   - Claude Code (stdio):    uses `claude` CLI OAuth (no key)
#   - GitHub Copilot:         uses your connected GitHub OAuth token
# For API-key providers, set the matching variable:
CAPILLARY_LLM_API_KEY=
ANTHROPIC_API_KEY=
OPENROUTER_API_KEY=
GEMINI_API_KEY=
# Containerized API reaching a codex app-server on the host? Run the bridge on
# the host (deno run --allow-net --allow-run --allow-env api/scripts/codex_ws_bridge.ts)
# and point at it:
# CODEX_APP_SERVER_URL=ws://host.docker.internal:7899
# BEDROCK_API_KEY=
# AWS_BEARER_TOKEN=

# ---------------------------------------------------------------------------
# Functional-test (CDP) agent — optional
# ---------------------------------------------------------------------------
# Point at an existing Chrome DevTools Protocol endpoint, or a Chrome binary to
# launch. Leave blank if you are not using the RetV browser agent.
CDP_BASE_URL=
CHROME_PATH=
