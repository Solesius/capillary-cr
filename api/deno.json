{
  "imports": {
    "worker_threads": "node:worker_threads",
    "module": "node:module",
    "path": "node:path",
    "fs": "node:fs",
    "url": "node:url",
    "os": "node:os",
    "crypto": "node:crypto",
    "perf_hooks": "node:perf_hooks"
  },
  "tasks": {
    "dev": "deno run --watch --allow-net --allow-env --allow-run --allow-read --allow-write --allow-ffi src/main.ts",
    "start": "deno run --allow-net --allow-env --allow-run --allow-read --allow-write --allow-ffi src/main.ts",
    "mcp": "deno run --allow-net --allow-env --allow-run src/mcp/server.ts",
    "cdp:retv": "deno run --allow-net --allow-env --allow-read scripts/cdp_retv_pipeline.ts",
    "review": "deno run --allow-net --allow-env --allow-run --allow-read --allow-write --allow-ffi scripts/review_cli.ts",
    "test": "deno test --allow-env --allow-net",
    "check": "deno check src/main.ts"
  },
  "fmt": {
    "lineWidth": 100,
    "singleQuote": false,
    "semiColons": true
  }
}
